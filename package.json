{
  "name": "theplacechatbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "knowledge:crawl": "tsx scripts/crawl-website.ts",
    "knowledge:parse-faq": "tsx scripts/parse-manager-faq.ts",
    "knowledge:prepare": "tsx scripts/prepare-knowledge.ts",
    "knowledge:verify": "tsx scripts/verify-knowledge.ts",
    "knowledge:refresh": "npm run knowledge:crawl && npm run knowledge:prepare && npm run knowledge:verify",
    "knowledge:sync": "tsx scripts/sync-file-search.ts",
    "knowledge:all": "npm run knowledge:crawl && npm run knowledge:parse-faq && npm run knowledge:prepare && npm run knowledge:sync -- --new-store",
    "knowledge:list-stores": "tsx scripts/list-file-search-stores.ts",
    "knowledge:delete-store": "tsx scripts/delete-file-search-store.ts"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "cheerio": "^1.2.0",
    "mammoth": "^1.12.0",
    "next": "16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^7",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
